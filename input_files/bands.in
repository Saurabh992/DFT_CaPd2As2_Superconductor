### bands.in: CaPd2As2 Band Structure (PRIMITIVE 5-atom cell)
&CONTROL
    calculation = 'bands',
    prefix      = 'capd2as2',     ! MUST match the prefix from your 5-atom scf.in
    outdir      = './tmp',
    pseudo_dir  = './pseudopotential', 
    verbosity   = 'high',
/
&SYSTEM
    ibrav       = 0,
    nat         = 5,
    ntyp        = 3,
    ecutwfc     = 70,                           ! Should match your scf.in
    ecutrho     = 560,                          ! Should match your scf.in
    occupations = 'fixed'
    smearing    = 'mv'
    degauss     = 0.01
    nbnd        = 100,
    noncolin      = .false.,
    lspinorb      = .false.,   ! SOC switches (keep consistent with scf)
/
&ELECTRONS
  conv_thr      = 1.0d-8,
  diagonalization='cg'
/
ATOMIC_SPECIES
  As  74.922   As.pbe-n-kjpaw_psl.1.0.0.UPF
  Ca  40.078   Ca.pbe-spn-kjpaw_psl.1.0.0.UPF
  Pd  106.42   Pd.pbe-spn-kjpaw_psl.1.0.0.UPF
! Cell MUST be identical to your 5-atom scf.in
CELL_PARAMETERS angstrom
   -2.1548951900     2.1548951900     5.1133625150
    2.1548951900    -2.1548951900     5.1133625150
    2.1548951900     2.1548951900    -5.1133625150
 
! Positions MUST be identical to your 5-atom scf.in
ATOMIC_POSITIONS crystal
As	0.3797473200	0.3797473200	0.0000000000
As	0.6202526800	0.6202526800	1.0000000000
Ca	0.0000000000	0.0000000000	0.0000000000
Pd	0.7500000000	0.2500000000	0.5000000000
Pd	0.2500000000	0.7500000000	0.5000000000

! This is the high-symmetry k-path (Γ → X → M → Γ → Z → R → A → Z)
! Using 80 points per segment for good resolution
K_POINTS crystal_b
8
0.0000 0.0000 0.0000   100   ! Γ
0.0000 0.5000 0.0000   100   ! X

0.5000 0.5000 0.0000   100   ! M
0.0000 0.0000 0.0000   100   ! Γ

0.0000 0.0000 0.5000   100   ! Z
0.0000 0.5000 0.5000   100   ! R

0.5000 0.5000 0.5000   100   ! A
0.0000 0.0000 0.5000   100   ! Z
